<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AgentManagement.Avalonia.ViewModels"
             x:Class="AgentManagement.Avalonia.Views.CrmPortalView"
             x:DataType="vm:CrmPortalViewModel">
    
    <Design.DataContext>
        <vm:CrmPortalViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#F3F4F6" Padding="15,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <!-- 左侧状态信息 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="🔗 CRM门户" 
                              FontSize="16" 
                              FontWeight="Bold"
                              VerticalAlignment="Center"
                              Foreground="#1F2937"/>
                    
                    <TextBlock Text="{Binding StatusMessage}" 
                              VerticalAlignment="Center"
                              Foreground="#6B7280"
                              FontSize="13"/>
                </StackPanel>
                
                <!-- 右侧操作按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="🌐 在浏览器中打开CRM" 
                            Command="{Binding OpenCrmInBrowserCommand}"
                            IsEnabled="{Binding IsLoggedIn}"
                            Classes="Small"
                            Background="#10B981"
                            Foreground="White"/>
                    
                    <Button Content="🚪 登出" 
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding IsLoggedIn}"
                            Classes="Small"
                            Background="#EF4444"
                            Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <!-- 登录面板 -->
            <StackPanel HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="20"
                       Width="350">
                
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="30">
                    <!--<Border.BoxShadow>
                        <BoxShadow BlurRadius="8" Offset="0,2" Color="#1A000000"/>
                    </Border.BoxShadow>-->
                    <StackPanel Spacing="20">
                        <TextBlock Text="CRM系统登录" 
                                  FontSize="20" 
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Foreground="#1F2937"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="账号" Foreground="#374151" FontSize="13"/>
                            <TextBox Text="{Binding Username}" 
                                    Watermark="请输入CRM账号"
                                    FontSize="14"
                                    Padding="10,8"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="密码" Foreground="#374151" FontSize="13"/>
                            <TextBox Text="{Binding Password}" 
                                    Watermark="请输入CRM密码"
                                    PasswordChar="*"
                                    FontSize="14"
                                    Padding="10,8"/>
                        </StackPanel>
                        
                        <Button Content="登录" 
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding !IsLoggingIn}"
                                HorizontalAlignment="Stretch"
                                Background="#3B82F6"
                                Foreground="White"
                                FontSize="14"
                                Padding="10,10"
                                CornerRadius="5"/>
                        
                        <ProgressBar IsIndeterminate="True" 
                                    IsVisible="{Binding IsLoggingIn}"
                                    Height="3"/>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="💡 提示：登录后将自动保存Token，下次打开时会自动登录。CRM将在默认浏览器中打开。"
                          HorizontalAlignment="Center"
                          Foreground="#9CA3AF"
                          FontSize="{StaticResource DefaultFontSize}"
                          TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

