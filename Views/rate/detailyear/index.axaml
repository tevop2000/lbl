<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AgentManagement.Avalonia.ViewModels.rate.detailyear"
             xmlns:controls="using:AgentManagement.Avalonia.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:AgentManagement.Avalonia.Converters"
             mc:Ignorable="d"
             x:Class="AgentManagement.Avalonia.Views.rate.detailyear.index"
             x:DataType="vm:indexViewModel"
             PointerPressed="OnUserControlPointerPressed">

    <UserControl.Resources>
        <converters:ProfitGreenRedColorConverter x:Key="ProfitGreenRedColorConverter"/>
        <converters:ProfitLabelBackgroundConverter x:Key="ProfitLabelBackgroundConverter"/>
        <converters:ProfitLabelTextConverter x:Key="ProfitLabelTextConverter"/>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <converters:InverseIntToBoolConverter x:Key="InverseIntToBoolConverter"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Background="#F7F9FB">
            <!-- 顶部选择器区域 -->
            <Border Background="#F7F9FB" Margin="0" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 左侧：DeptManagerAgentSelector -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- 间距 -->
                        <ColumnDefinition Width="24"/>
                        <!-- 右侧：预测年份选择 + Excel导入 -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- 左侧：DeptManagerAgentSelector -->
                    <controls:DeptManagerAgentSelector x:Name="SelectorControl" Grid.Column="0"/>
                    
                    <!-- 右侧：预测年份选择 + Excel导入 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                        <!-- 预测年份选择 -->
                        <StackPanel>
                            <TextBlock Text="预测年份" FontSize="11" Foreground="#6B7280" Margin="0,0,0,8"/>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left" Height="32">
                                <StackPanel Orientation="Horizontal" Margin="4,0" Spacing="4">
                                    <Button x:Name="BtnYear1" 
                                            Click="BtnYear1_Click"
                                            Background="#3B82F6"
                                            Foreground="White"
                                            BorderBrush="#3B82F6"
                                            BorderThickness="0"
                                            Padding="16,0"
                                            CornerRadius="4"
                                            Height="32">
                                        <TextBlock x:Name="TxtYear1" Text="" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="BtnYear2" 
                                            Click="BtnYear2_Click"
                                            Background="White"
                                            Foreground="#64748B"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0"
                                            Padding="16,0"
                                            CornerRadius="4"
                                            Height="32">
                                        <TextBlock x:Name="TxtYear2" Text="" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Excel导入和模板下载 -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel>
                                <TextBlock Text="数据导入" FontSize="11" Foreground="#6B7280" Margin="0,0,0,8"/>
                                <Button Content="📊 Excel导入"
                                        x:Name="ExcelImportButton"
                                        Click="ExcelImportButton_Click"
                                        Background="#ECFDF5"
                                        Foreground="#059669"
                                        BorderBrush="#A7F3D0"
                                        BorderThickness="1"
                                        Padding="12,0"
                                        CornerRadius="6"
                                        Height="32">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Excel导入" FontSize="{StaticResource DefaultFontSize}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="模板下载" FontSize="11" Foreground="#6B7280" Margin="0,0,0,8"/>
                                <Button Content="📥 模板下载"
                                        x:Name="TemplateDownloadButton"
                                        Click="TemplateDownloadButton_Click"
                                        Background="#EFF6FF"
                                        Foreground="#3B82F6"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        Padding="12,0"
                                        CornerRadius="6"
                                        Height="32">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="📥" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="模板下载" FontSize="{StaticResource DefaultFontSize}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 顶部分割线 -->
            <Border Height="1" Background="#E2E8F0" Margin="0"/>
            
            <!-- 顶部标题 -->
            <Grid Margin="24,24,24,0">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Grid.Column="0">
                            <TextBlock Text="📊" FontSize="24" VerticalAlignment="Center"/>
                            <TextBlock Text="年度盈亏预测" FontWeight="Bold" FontSize="28" Foreground="#1A2533" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="基于量本利模型 (CVP) 以「整年」为单位预测盈亏" FontSize="14" Foreground="#94A3B8" Margin="32,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 统计卡片 -->
            <Grid Margin="16,24,16,0" ColumnDefinitions="*,*,*,*">
                <!-- 卡片1：年目标销量 -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Vertical" Height="48">
                            <Border Width="28" Height="28" Background="#E0F2FE" CornerRadius="8" HorizontalAlignment="Left">
                                <TextBlock Text="🎯" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="年目标销量" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TargetSales, StringFormat=\{0:N0\}}" FontSize="32" FontWeight="Bold" Foreground="#1A2533" Margin="0,12,0,0"/>
                        <TextBlock Text="只" FontSize="14" Foreground="#94A3B8"/>
                    </StackPanel>
                </Border>

                <!-- 卡片2：盈亏平衡点达成率 -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Vertical" Height="48">
                            <Border Width="28" Height="28" Background="#FEF3C7" CornerRadius="8" HorizontalAlignment="Left">
                                <TextBlock Text="📈" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="盈亏平衡点达成率" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AchievementRatePercent , StringFormat=\{0:F2\}%}" FontSize="32" FontWeight="Bold" Foreground="#D97706" Margin="0,12,0,0"/>
                        <ProgressBar Value="{Binding AchievementRatePercent}" Maximum="100" Height="6" Margin="0,12,0,4" 
                                         Background="#F5F5F5" Foreground="#F59E0B" 
                                         CornerRadius="4" />
                        <TextBlock Text="{Binding AchievementRatePercent, StringFormat=进度: \{0:F1\}%}" FontSize="{StaticResource DefaultFontSize}" Foreground="#94A3B8"/>
                    </StackPanel>
                </Border>

                <!-- 卡片3：盈亏平衡点达成销量 -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Vertical" Height="48">
                            <Border Width="28" Height="28" Background="#EDE9FE" CornerRadius="8" HorizontalAlignment="Left">
                                <TextBlock Text="📊" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="盈亏平衡点达成销量" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding BreakSales, StringFormat=\{0:N0\}}" FontSize="32" FontWeight="Bold" Foreground="#7C3AED" Margin="0,12,0,0"/>
                        <TextBlock Text="只" FontSize="14" Foreground="#94A3B8"/>
                    </StackPanel>
                </Border>

                <!-- 卡片4：调整后净利润 -->
                <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,Auto" Height="48">
                            <StackPanel Orientation="Vertical">
                                <Border Width="28" Height="28" Background="{Binding AdjustedNetProfit, Converter={StaticResource ProfitLabelBackgroundConverter}}" CornerRadius="8" HorizontalAlignment="Left">
                                    <TextBlock Text="💰" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="调整后净利润" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{Binding AdjustedNetProfit, Converter={StaticResource ProfitLabelBackgroundConverter}}" CornerRadius="4" Padding="4,2" VerticalAlignment="Top">
                                <TextBlock Text="{Binding AdjustedNetProfit, Converter={StaticResource ProfitLabelTextConverter}}" FontSize="10" FontWeight="Bold" Foreground="{Binding AdjustedNetProfit, Converter={StaticResource ProfitGreenRedColorConverter}}"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding AdjustedNetProfit}" FontSize="32" FontWeight="Bold" Foreground="{Binding AdjustedNetProfit, Converter={StaticResource ProfitGreenRedColorConverter}}" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 年度数据明细表格 -->
            <Border Margin="16,24,16,32" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <Grid Margin="24,20,24,0" ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📋" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Text="年度数据明细" FontWeight="Bold" FontSize="16" Foreground="#1A2533"/>
                            <!--<TextBlock Text="{Binding CurrentAgentName}" FontSize="14" Foreground="#64748B"/>
                            <TextBlock Text="·" FontSize="14" Foreground="#94A3B8"/>
                            <TextBlock Text="{Binding YearMonth, StringFormat=\{0\}年}" FontSize="14" Foreground="#64748B"/>-->
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ExportDataCommand}" Background="#059669" Foreground="White" 
                                Padding="12,6" CornerRadius="6" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="📥" FontSize="14"/>
                                <TextBlock Text="导出数据" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                        <!-- Tab选择器 -->
                        <TabControl Margin="16,16,16,0" SelectedIndex="{Binding SelectedTabIndex}" Height="40">
                            <TabItem Header="当前方案" FontSize="14"/>
                            <TabItem Header="历史方案" FontSize="14"/>
                        </TabControl>

                    <!-- 表格 -->
                    <Border Margin="16,16,16,16" BorderBrush="#E2E8F0" BorderThickness="1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- 当前方案表格 -->
                                <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}}">
                                    <!-- 表头 -->
                                    <Grid ColumnDefinitions="2*,1*,1*,1*,1*,1*,1*,1*,1*,1*" Background="#F8FAFC">
                                        <TextBlock Grid.Column="0" Text="代理商" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="1" Text="年份" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="2" Text="年目标销量" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="3" Text="达成率" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="4" Text="提升后销量" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="5" Text="销量增长毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="6" Text="结构优化毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="7" Text="溢价毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="8" Text="总超出毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="9" Text="调整后净利润" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                    </Grid>

                                    <!-- 数据行 -->
                                    <ItemsControl ItemsSource="{Binding YearDataDetails}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:YearDataDetail">
                                                <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                                                    <Grid ColumnDefinitions="2*,1*,1*,1*,1*,1*,1*,1*,1*,1*">
                                                        <TextBlock Grid.Column="0" Text="{Binding AgentName}" FontSize="{StaticResource DefaultFontSize}" Foreground="#1A2533" Padding="12,8"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Year}" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B" Padding="12,8"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding AnnualTargetSales, StringFormat=\{0:N0\}}" FontSize="{StaticResource DefaultFontSize}" Foreground="#1A2533" Padding="12,8"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding AchievementRatePercent, StringFormat=\{0:F2\}%}" FontSize="{StaticResource DefaultFontSize}" Foreground="#D97706" Padding="12,8"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding ImprovedSales, StringFormat=\{0:N0\}}" FontSize="{StaticResource DefaultFontSize}" Foreground="#7C3AED" Padding="12,8"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding SalesGrowthMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding SalesGrowthMargin, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                        <TextBlock Grid.Column="6" Text="{Binding StructureOptimizationMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding StructureOptimizationMargin, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                        <TextBlock Grid.Column="7" Text="{Binding PremiumMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding PremiumMargin, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                        <Border Grid.Column="8" Background="{Binding TotalExcessMargin, Converter={StaticResource ProfitLabelBackgroundConverter}}" Padding="12,8">
                                                            <TextBlock Text="{Binding TotalExcessMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding TotalExcessMargin, Converter={StaticResource ProfitGreenRedColorConverter}}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="9" Text="{Binding AdjustedNetProfit}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding AdjustedNetProfit, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                
                                <!-- 历史方案表格 -->
                                <StackPanel IsVisible="{Binding SelectedTabIndex, Converter={StaticResource InverseIntToBoolConverter}}">
                                    <!-- 表头 -->
                                    <Grid ColumnDefinitions="2*,1*,1*,1*,1*,1*,1*,1*,1*,1*,80" Background="#F8FAFC">
                                        <TextBlock Grid.Column="0" Text="代理商" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="1" Text="年份" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="2" Text="年目标销量" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="3" Text="达成率" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="4" Text="提升后销量" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="5" Text="销量增长毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="6" Text="结构优化毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="7" Text="溢价毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="8" Text="总超出毛利" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="9" Text="版本ID" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                        <TextBlock Grid.Column="10" Text="操作" FontSize="{StaticResource DefaultFontSize}" FontWeight="Bold" Foreground="#64748B" Padding="12,8"/>
                                    </Grid>

                                    <!-- 数据行 -->
                                    <ItemsControl ItemsSource="{Binding HistoricalYearDataDetails}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                                                    <Grid ColumnDefinitions="2*,1*,1*,1*,1*,1*,1*,1*,1*,1*,80">
                                                        <TextBlock Grid.Column="0" Text="{Binding AgentName}" FontSize="{StaticResource DefaultFontSize}" Foreground="#1A2533" Padding="12,8"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Year}" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B" Padding="12,8"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding AnnualTargetSales, StringFormat=\{0:N0\}}" FontSize="{StaticResource DefaultFontSize}" Foreground="#1A2533" Padding="12,8"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding AchievementRatePercent, StringFormat=\{0:F2\}%}" FontSize="{StaticResource DefaultFontSize}" Foreground="#D97706" Padding="12,8"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding ImprovedSales, StringFormat=\{0:N0\}}" FontSize="{StaticResource DefaultFontSize}" Foreground="#7C3AED" Padding="12,8"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding SalesGrowthMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding SalesGrowthMargin, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                        <TextBlock Grid.Column="6" Text="{Binding StructureOptimizationMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding StructureOptimizationMargin, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                        <TextBlock Grid.Column="7" Text="{Binding PremiumMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding PremiumMargin, Converter={StaticResource ProfitGreenRedColorConverter}}" Padding="12,8"/>
                                                        <Border Grid.Column="8" Background="{Binding TotalExcessMargin, Converter={StaticResource ProfitLabelBackgroundConverter}}" Padding="12,8">
                                                            <TextBlock Text="{Binding TotalExcessMargin}" FontSize="{StaticResource DefaultFontSize}" Foreground="{Binding TotalExcessMargin, Converter={StaticResource ProfitGreenRedColorConverter}}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="9" Text="{Binding VersionId, StringFormat=\{0\}}" FontSize="{StaticResource DefaultFontSize}" Foreground="#7C3AED" Padding="12,8"/>
                                                        <Button Grid.Column="10" Content="详情" 
                                                                FontSize="11" Padding="4,2" Margin="2"
                                                                Background="#3B82F6" Foreground="White"
                                                                CornerRadius="3" HorizontalAlignment="Center"
                                                                Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
					
					<!-- 底部说明 -->
					<Border Background="#F9FAFB" Padding="15,10" BorderBrush="#E5E7EB" BorderThickness="1,0,0,0">
						<StackPanel Orientation="Horizontal" Spacing="20">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<TextBlock Text="ℹ️" FontSize="{StaticResource DefaultFontSize}"/>
								<TextBlock Text="初始数据由年度数据汇总，可在参数配置面板修改" FontSize="11" Foreground="#6B7280"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Border Background="#EFF6FF" Width="12" Height="12" CornerRadius="2"/>
								<TextBlock Text="总超出毛利" FontSize="11" Foreground="#6B7280"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Border Background="#D1FAE5" Width="12" Height="12" CornerRadius="2"/>
								<TextBlock Text="盈利" FontSize="11" Foreground="#6B7280"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Border Background="#EF4444" Width="12" Height="12" CornerRadius="2"/>
								<TextBlock Text="亏损" FontSize="11" Foreground="#6B7280"/>
							</StackPanel>
						</StackPanel>
					</Border>
					
                </StackPanel>
            </Border>

            <!-- 参数配置面板 -->
            <Border Margin="16,0,16,32" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <!-- 面板标题 -->
                    <StackPanel Orientation="Horizontal" Margin="24,16,24,0" Spacing="8">
                        <TextBlock Text="⚙️" FontSize="16" Foreground="#64748B"/>
                        <TextBlock Text="参数配置" FontWeight="Bold" FontSize="16" Foreground="#1A2533"/>
                    </StackPanel>

                    <!-- 年度参数设置面板 -->
                    <Border Margin="16,16,16,0" Background="#EFF6FF" CornerRadius="8">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Margin="16,12,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="📊" FontSize="14" Foreground="#64748B"/>
                                        <TextBlock Text="年度参数设置面板" FontSize="14" FontWeight="Bold" Foreground="#1A2533"/>
                                    </StackPanel>
                                    <!--<TextBlock Text="北京华北代理商" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B" Margin="0,4,0,0"/>-->
                                </StackPanel>
								<!--<Border Grid.Column="1" Background="White" CornerRadius="4" Padding="8,4" Margin="0,12,16,12">
                                    <TextBlock Text="2027年" FontSize="{StaticResource DefaultFontSize}" Foreground="#3B82F6"/>
                                </Border>-->
                            </Grid>

                            <!-- 左右布局 -->
                            <Grid Margin="16,12,16,12" ColumnDefinitions="*,*">
                                <!-- 左侧：基础设置 -->
								<!-- 左侧：基础设置 -->
								<StackPanel Grid.Column="0">
									<Border Background="White" CornerRadius="8" Padding="16">
										<StackPanel>
											<!-- 基础设置标题 -->
											<Grid Margin="0,0,0,16" ColumnDefinitions="Auto,*">
												<StackPanel Orientation="Horizontal" Spacing="4">
													<TextBlock Text="💰" FontSize="14"/>
													<TextBlock Text="基础设置" FontSize="14" FontWeight="Bold" Foreground="#64748B"/>
												</StackPanel>
											</Grid>

											<!-- ===== 年目标销量分组 ===== -->
											<Border Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,0,0,16">
												<Grid ColumnDefinitions="*,80,40">
													<StackPanel VerticalAlignment="Center">
														<TextBlock Text="年目标销量" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B"/>													
													</StackPanel>
													<TextBox Grid.Column="1" Text="{Binding ConfigTargetSales}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="{StaticResource DefaultFontSize}" Padding="8,4"
														 BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"
														 HorizontalAlignment="Right" Width="80" LostFocus="TextBox_LostFocus" TextAlignment="Right"/>
													<TextBlock Grid.Column="2" Text="只" FontSize="{StaticResource DefaultFontSize}" Foreground="#94A3B8"
														   HorizontalAlignment="Right" Margin="8,0,0,0" VerticalAlignment="Center"/>
												</Grid>
											</Border>

											<!-- 固定成本标题 -->
											<TextBlock Text="固定成本" FontSize="13" FontWeight="Bold" Foreground="#1A2533" Margin="0,0,0,12"/>

                                            <!-- 动态固定成本列表 -->
                                            <ItemsControl ItemsSource="{Binding FixedCostItems}" Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:indexViewModel+ExpenseItemViewModel">
                                                        <Grid Margin="0,0,0,12" ColumnDefinitions="*,80,40">
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ExpenseType}" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B"/>                                                
                                                            </StackPanel>
                                                            <TextBox Grid.Column="1" Text="{Binding Amount}" FontSize="{StaticResource DefaultFontSize}" Padding="8,4"
                                                                     BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                                                     HorizontalAlignment="Right" Width="80" TextAlignment="Right"
                                                                     LostFocus="ExpenseItemTextBox_LostFocus"
                                                                     Tag="{Binding ExpenseType}"/>
                                                            <TextBlock Grid.Column="2" Text="元" FontSize="{StaticResource DefaultFontSize}" Foreground="#94A3B8"
                                                                       HorizontalAlignment="Right" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 水电招待费 - 带分割线 -->
                                            <Border Margin="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,0,0,16"/>

											<TextBlock Text="收益项目" FontSize="13" FontWeight="Bold" Foreground="#1A2533" Margin="0,0,0,12"/>
											
                                            <!-- 动态收益项目列表 -->
                                            <ItemsControl ItemsSource="{Binding IncomeItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:indexViewModel+ExpenseItemViewModel">
                                                        <Grid Margin="0,0,0,12" ColumnDefinitions="*,80,40">
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ExpenseType}" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B"/>                                                
                                                            </StackPanel>
                                                            <TextBox Grid.Column="1" Text="{Binding Amount}" FontSize="{StaticResource DefaultFontSize}" Padding="8,4"
                                                                     BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                                                     HorizontalAlignment="Right" Width="80" TextAlignment="Right"
                                                                     LostFocus="ExpenseItemTextBox_LostFocus"
                                                                     Tag="{Binding ExpenseType}"/>
                                                            <TextBlock Grid.Column="2" Text="元" FontSize="{StaticResource DefaultFontSize}" Foreground="#94A3B8"
                                                                       HorizontalAlignment="Right" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 添加收益项目按钮 -->
                                            <Button Margin="0,0,0,0" Background="Transparent" BorderBrush="#3B82F6" BorderThickness="1" Foreground="#3B82F6" 
                                                    Padding="8,4" CornerRadius="4" HorizontalAlignment="Right" Command="{Binding AddExpenseItemCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <TextBlock Text="+" FontSize="{StaticResource DefaultFontSize}"/>
                                                    <TextBlock Text="添加收益项目" FontSize="10"/>
                                                </StackPanel>
                                            </Button>
										</StackPanel>
									</Border>
								</StackPanel>

                                <!-- 右侧：产品设置和结构优化 -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <!-- 产品设置 -->
                                    <Border Background="White" CornerRadius="8" Padding="16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,*">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="📦" FontSize="14"/>
                                                    <TextBlock Text="产品设置" FontSize="14" FontWeight="Bold" Foreground="#64748B"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" 
                                                        Background="{Binding ProportionSumBackground}" 
                                                        CornerRadius="6" 
                                                        Padding="8,4" 
                                                        HorizontalAlignment="Right">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <TextBlock Text="{Binding ProportionSumText}" 
                                                                   FontSize="14" 
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding ProportionSumForeground}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- 产品表格 -->
                                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                                                <StackPanel>
                                                    <!-- 表头 -->
                                                    <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Background="#F8FAFC">
                                                        <TextBlock Grid.Column="0" Text="产品型号" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                        <TextBlock Grid.Column="1" Text="占比" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                        <TextBlock Grid.Column="2" Text="售价(元)" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                        <TextBlock Grid.Column="3" Text="进价(元)" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                        <TextBlock Grid.Column="4" Text="提成(元)" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                    </Grid>

                                                    <!-- 动态数据行 -->
                                                    <ItemsControl ItemsSource="{Binding ProductStructures}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Margin="0,2">
                                                                    <TextBlock Grid.Column="0" Text="{Binding ItemModel}" VerticalAlignment="Center" FontSize="11" Foreground="#1A2533" Padding="8,6"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding StructureRatio, Mode=TwoWay}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="1" Margin="8,0,0,0"
                                                                             LostFocus="ProductStructureTextBox_LostFocus"/>
                                                                    <TextBox Grid.Column="2" Text="{Binding RemiumPrice, Mode=TwoWay, StringFormat=\{0:N0\}}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="1" Margin="8,0,0,0"
                                                                             LostFocus="ProductStructureTextBox_LostFocus"/>
                                                                    <TextBox Grid.Column="3" Text="{Binding RemiumCost, Mode=TwoWay, StringFormat=\{0:N0\}}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="1" Margin="8,0,0,0"
                                                                             LostFocus="ProductStructureTextBox_LostFocus"/>
                                                                    <TextBox Grid.Column="4" Text="{Binding Commission, Mode=TwoWay, StringFormat=\{0:N0\}}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="1" Margin="8,0,0,0"
                                                                             LostFocus="ProductStructureTextBox_LostFocus"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- 添加产品型号按钮 -->
                                            <Button Margin="0,8,0,0" Background="Transparent" BorderBrush="#3B82F6" BorderThickness="1" Foreground="#3B82F6" 
                                                    Padding="8,4" CornerRadius="4" HorizontalAlignment="Right" Command="{Binding AddProductCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <TextBlock Text="+" FontSize="{StaticResource DefaultFontSize}"/>
                                                    <TextBlock Text="添加产品型号" FontSize="10"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- 结构优化设置 -->
                                    <Border Background="White" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,*">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="📈" FontSize="14"/>
                                                    <TextBlock Text="结构优化设置（按产品）" FontSize="14" FontWeight="Bold" Foreground="#64748B"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" 
                                                        Background="{Binding OptimizationSumBackground}" 
                                                        BorderBrush="{Binding OptimizationSumBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="6" 
                                                        Padding="8,4" 
                                                        HorizontalAlignment="Right">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <TextBlock Text="{Binding OptimizationSumText}" 
                                                                   FontSize="14" 
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding OptimizationSumForeground}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- 年销售量增加百分比 -->
                                            <Grid Margin="0,0,0,8" ColumnDefinitions="*,Auto">
                                                <StackPanel>
                                                    <TextBlock Text="销售量增加率" FontSize="{StaticResource DefaultFontSize}" Foreground="#64748B"/>
                                                    
                                                    <!-- 可拖动的进度条 - ProgressBar + 隐藏 Slider -->
                                                    <Grid Height="20" Margin="0,4,0,0">
                                                        <ProgressBar Value="{Binding GrowthRate}"
                                                                     Minimum="-100"
                                                                     Maximum="100"
                                                                     Height="4"
                                                                     CornerRadius="4"
                                                                     Background="#E2E8F0"
                                                                     Foreground="#3B82F6"
                                                                     VerticalAlignment="Center"
                                                                     ValueChanged="ProgressBarControl_ValueChanged"/>
                                                            
                                                        <Slider x:Name="HiddenSlider"
                                                                Value="{Binding GrowthRate}"
                                                                Minimum="-100"
                                                                Maximum="100"
                                                                SmallChange="0.1"
                                                                LargeChange="1"
                                                                TickFrequency="0.1"
                                                                IsSnapToTickEnabled="True"
                                                                Opacity="0"
                                                                Cursor="Hand"/>
                                                    </Grid>
                                                    
                                                    <!-- 销售量达成率显示 -->
                                                    <Border 
                                                            Background="{Binding AchievementRateBackground}" 
                                                            BorderBrush="{Binding AchievementRateBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="6" 
                                                            Padding="8,4" 
                                                            HorizontalAlignment="Left"
                                                            Margin="0,8,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                                            <TextBlock Text="{Binding AchievementRateText}" 
                                                                       FontSize="14" 
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding AchievementRateForeground}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto" VerticalAlignment="Center">
                                                    <TextBox Text="{Binding GrowthRate, StringFormat='{}{0:F2}', Mode=TwoWay}" 
                                                           FontSize="{StaticResource DefaultFontSize}" 
                                                           FontWeight="Bold" 
                                                           Foreground="#3B82F6"
                                                           Background="#F8FAFC"
                                                           BorderBrush="#E2E8F0"
                                                           BorderThickness="1"
                                                           CornerRadius="3"
                                                           Padding="4,2"
                                                           VerticalAlignment="Center"
                                                           VerticalContentAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Width="60"/>
                                                    <TextBlock Grid.Column="1" 
                                                             Text="%" 
                                                             FontSize="{StaticResource DefaultFontSize}" 
                                                             FontWeight="Bold" 
                                                             Foreground="#3B82F6"
                                                             VerticalAlignment="Center"
                                                             Margin="4,0,0,0"/>
                                                </Grid>
                                            </Grid>

                                            <!-- 优化表格 -->
                                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                                                <StackPanel>
                                                    <!-- 表头 -->
                                                    <Grid ColumnDefinitions="2*,,1*,1*" Background="#F8FAFC">
                                                        <TextBlock Grid.Column="0" Text="产品型号" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
														<!--<TextBlock Grid.Column="1" Text="销量占比" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>-->
                                                        <TextBlock Grid.Column="1" Text="结构优化" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                        <TextBlock Grid.Column="2" Text="溢价/折扣" FontSize="10" FontWeight="Bold" Foreground="#64748B" Padding="8,6"/>
                                                    </Grid>

                                                    <!-- 动态数据行 -->
                                                    <ItemsControl ItemsSource="{Binding ProductStructures}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnDefinitions="2*,1*,1*" Margin="0,2">
                                                                    <TextBlock Grid.Column="0" Text="{Binding ItemModel}" VerticalAlignment="Center" FontSize="11" Foreground="#1A2533" Padding="8,6"/>
																	<!--<TextBlock Grid.Column="1" Text="{Binding SalesRatio, StringFormat=\{0:F2\}%}" VerticalAlignment="Center" FontSize="11" Foreground="#059669" Padding="8,6" Margin="8,0,0,0"/>-->
                                                                    <TextBox Grid.Column="1" Text="{Binding PriceAdjustment, Mode=TwoWay, StringFormat=\{0:F2\}}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Padding="4,2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="3" Margin="8,0,0,0"
                                                                             LostFocus="ProductStructureTextBox_LostFocus"/>
                                                                    <TextBox Grid.Column="2" Text="{Binding PremiumDiscount, Mode=TwoWay, StringFormat=\{0:F2\}}" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Padding="4,2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="3" Margin="8,0,0,0"
                                                                             LostFocus="ProductStructureTextBox_LostFocus"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 预测计算结果按钮 -->
                    <Button Margin="16,16,16,20" x:Name="PreviewButton" Click="PreviewButton_Click" Background="#3B82F6" Foreground="White" 
                            Padding="16,12" CornerRadius="8" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="16"/>
                            <TextBlock Text="预览计算结果" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

